// GENERATED by utils/dasgen/gen_shader_conformance.das — DO NOT EDIT
// regen: daslang utils/dasgen/gen_shader_conformance.das
options gen2
options indenting = 4
options no_aot     // invokes the compiler at runtime (compile_file) — not AOT-linkable

// Fail-closed conformance rows: each fixture uses one shader-illegal type; the emitter
// must reject with a clean diagnostic (same contract as tests/spirv/test_fail_closed.das).

require dastest/testing_boost public
require daslib/ast
require strings

def private compile_issues(file_path : string) : tuple<ok : bool; issues : string> {
    var okFlag = false
    var issuesText = ""
    var inscope access <- make_file_access("")
    using() $(var mg : ModuleGroup) {
        using() $(var cop : CodeOfPolicies) {
            cop.threadlock_context = true
            compile_file(file_path, access, unsafe(addr(mg)), cop) $(ok, _program, issues) {
                okFlag = ok
                issuesText := issues
            }
        }
    }
    return (ok = okFlag, issues = issuesText)
}

def private check_rejects(t : T?; fixture, needle : string) {
    let r = compile_issues("{get_das_root()}/tests/glsl/_fail_closed/{fixture}.das")
    t |> success(!r.ok, "{fixture}: compilation fails (fail-closed)")
    t |> success(find(r.issues, needle) >= 0, "{fixture}: error mentions '{needle}'")
    if (r.ok || find(r.issues, needle) < 0) {
        to_log(LOG_ERROR, "FAIL-CLOSED {fixture}: ok={r.ok}, issues=\n{r.issues}\n")
    }
}

[test]
def test_conf_rejects_glsl(t : T?) {
    t |> run("conformance reject rows fail closed") <| @(t : T?) {
        check_rejects(t, "_fc_conf_memzero", "memzero is not supported")
        check_rejects(t, "_fc_conf_float16", "unsupported type tFloat16")
        check_rejects(t, "_fc_conf_half2", "unsupported type tHalf2")
        check_rejects(t, "_fc_conf_half3", "unsupported type tHalf3")
        check_rejects(t, "_fc_conf_half4", "unsupported type tHalf4")
        check_rejects(t, "_fc_conf_half8", "is CPU-only")
        check_rejects(t, "_fc_conf_int8", "unsupported type tInt8")
        check_rejects(t, "_fc_conf_uint8", "unsupported type tUInt8")
        check_rejects(t, "_fc_conf_int16", "unsupported type tInt16")
        check_rejects(t, "_fc_conf_uint16", "unsupported type tUInt16")
        check_rejects(t, "_fc_conf_short2", "unsupported type tShort2")
        check_rejects(t, "_fc_conf_short3", "unsupported type tShort3")
        check_rejects(t, "_fc_conf_short4", "unsupported type tShort4")
        check_rejects(t, "_fc_conf_short8", "is CPU-only")
        check_rejects(t, "_fc_conf_ushort2", "unsupported type tUShort2")
        check_rejects(t, "_fc_conf_ushort3", "unsupported type tUShort3")
        check_rejects(t, "_fc_conf_ushort4", "unsupported type tUShort4")
        check_rejects(t, "_fc_conf_ushort8", "is CPU-only")
        check_rejects(t, "_fc_conf_byte2", "unsupported type tByte2")
        check_rejects(t, "_fc_conf_byte3", "unsupported type tByte3")
        check_rejects(t, "_fc_conf_byte4", "unsupported type tByte4")
        check_rejects(t, "_fc_conf_byte8", "is CPU-only")
        check_rejects(t, "_fc_conf_byte16", "is CPU-only")
        check_rejects(t, "_fc_conf_ubyte2", "unsupported type tUByte2")
        check_rejects(t, "_fc_conf_ubyte3", "unsupported type tUByte3")
        check_rejects(t, "_fc_conf_ubyte4", "unsupported type tUByte4")
        check_rejects(t, "_fc_conf_ubyte8", "is CPU-only")
        check_rejects(t, "_fc_conf_ubyte16", "is CPU-only")
        check_rejects(t, "_fc_lattice_ubo", "16/8-bit lattice members have no std140 layout")
        check_rejects(t, "_fc_lattice_ssbo", "16/8-bit lattice types are not supported yet")
    }
}
