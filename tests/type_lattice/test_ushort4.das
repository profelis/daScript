        c = ushort4(5u, 6u, 7u, 8u)
        t |> success(a == ushort4(1u, 2u, 3u, 4u), "source unchanged")
        t |> success(c == ushort4(5u, 6u, 7u, 8u), "copy reassigned")
    }
    t |> run("pass and return by value") @(t : T?) {
