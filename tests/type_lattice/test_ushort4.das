        t |> success(a.xy == ushort2(1u, 2u), "pair read")
        a.w = uint16(9)
        t |> equal(a.w, uint16(9))
        a.xy = ushort2(7u, 8u)
        t |> equal(a.x, uint16(7))
        t |> equal(a.y, uint16(8))
    }
    t |> run("s-namespace swizzle") @(t : T?) {
