        t |> success(arr[1] == ushort4(5u, 6u, 7u, 8u), "array read 1")
        delete arr
    }
    t |> run("archive round trip") @(t : T?) {
        var a = ushort4(1u, 2u, 3u, 4u)
        var data <- mem_archive_save(a)
        var back : ushort4
        data |> mem_archive_load(back)
        delete data
        t |> success(back == a, "mem archive")
    }
    t |> run("print") @(t : T?) {
        let a = ushort4(1u, 2u, 3u, 4u)
