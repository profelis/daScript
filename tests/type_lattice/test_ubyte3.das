[test]
def test_ubyte3_conformance(t : T?) {
    t |> run("sizeof and alignof") @(t : T?) {
        t |> equal(typeinfo sizeof(type<ubyte3>), 3)
        t |> equal(typeinfo alignof(type<ubyte3>), 1)
