        let c = ubyte3(2u, 3u, 4u)
        t |> success(a == b, "a == b")
        t |> success(a != c, "a != c")
        t |> success(ubyte3(3u) == ubyte3(3u, 3u, 3u), "splat ctor")
    }
    t |> run("copy is value copy") @(t : T?) {
        let a = ubyte3(1u, 2u, 3u)
        var c = a
        c = ubyte3(5u, 6u, 7u)
        t |> success(a == ubyte3(1u, 2u, 3u), "source unchanged")
        t |> success(c == ubyte3(5u, 6u, 7u), "copy reassigned")
    }
    t |> run("pass and return by value") @(t : T?) {
        let a = ubyte3(1u, 2u, 3u)
        t |> success(roundtrip_ubyte3(a) == a, "roundtrip")
    }
    t |> run("index read and write") @(t : T?) {
        var a = ubyte3(1u, 2u, 3u)
        t |> equal(a[0], uint8(1))
        t |> equal(a[1], uint8(2))
        t |> equal(a[2], uint8(3))
        a[2] = uint8(9)
        t |> equal(a[2], uint8(9))
    }
    t |> run("swizzle") @(t : T?) {
        var a = ubyte3(1u, 2u, 3u)
        t |> equal(a.x, uint8(1))
        t |> equal(a.z, uint8(3))
        t |> success(a.zyx == ubyte3(3u, 2u, 1u), "reverse read")
        t |> success(a.xy == ubyte2(1u, 2u), "pair read")
        a.z = uint8(9)
        t |> equal(a.z, uint8(9))
        a.xy = ubyte2(7u, 8u)
        t |> equal(a.x, uint8(7))
        t |> equal(a.y, uint8(8))
    }
    t |> run("s-namespace swizzle") @(t : T?) {
        var a = ubyte3(1u, 2u, 3u)
        t |> equal(a.s2, uint8(3))
        t |> success(a.s20 == ubyte2(3u, 1u), "pair reorder")
        a.s0 = uint8(9)
        t |> equal(a.s0, uint8(9))
    }
    t |> run("struct field and layout") @(t : T?) {
        var w = Wrap_ubyte3(pad = uint8(1), v = ubyte3(1u, 2u, 3u))
        t |> success(w.v == ubyte3(1u, 2u, 3u), "field read")
        w.v = ubyte3(5u, 6u, 7u)
        t |> success(w.v == ubyte3(5u, 6u, 7u), "field write")
        t |> equal(typeinfo sizeof(type<Wrap_ubyte3>), 4)
    }
    t |> run("array element") @(t : T?) {
        var arr : array<ubyte3>
        arr |> push(ubyte3(1u, 2u, 3u))
        arr |> push(ubyte3(5u, 6u, 7u))
        t |> equal(length(arr), 2)
        t |> success(arr[0] == ubyte3(1u, 2u, 3u), "array read 0")
        t |> success(arr[1] == ubyte3(5u, 6u, 7u), "array read 1")
        delete arr
    }
    t |> run("archive round trip") @(t : T?) {
        var a = ubyte3(1u, 2u, 3u)
        var data <- mem_archive_save(a)
        var back : ubyte3
        data |> mem_archive_load(back)
        delete data
        t |> success(back == a, "mem archive")
    }
    t |> run("print") @(t : T?) {
        let a = ubyte3(1u, 2u, 3u)
        let s = "{a}"
        t |> success(!empty(s), "interpolates")
    }
    t |> run("converts") @(t : T?) {
        let a = ubyte3(1u, 2u, 3u)
        let w = uint3(a)
        t |> success(w == uint3(1u, 2u, 3u), "widen")
        t |> success(ubyte3(w) == a, "narrow round trip")
        let s = ubyte3_sat(uint3(100000u, 1u, 2u))
        t |> success(s == ubyte3(255u, 1u, 2u), "sat clamp")
