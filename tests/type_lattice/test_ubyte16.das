        t |> equal(a.sf, uint8(16))
        t |> success(a.sf0 == ubyte2(16u, 1u), "pair reorder")
        t |> success(a.lo == ubyte8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u), ".lo")
        t |> success(a.hi == ubyte8(9u, 10u, 11u, 12u, 13u, 14u, 15u, 16u), ".hi")
