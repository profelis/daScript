        let c = ubyte16(2u, 3u, 4u, 5u, 6u, 7u, 8u, 9u, 10u, 11u, 12u, 13u, 14u, 15u, 16u, 17u)
        t |> success(a == b, "a == b")
        t |> success(a != c, "a != c")
        t |> success(ubyte16(3u) == ubyte16(3u, 3u, 3u, 3u, 3u, 3u, 3u, 3u, 3u, 3u, 3u, 3u, 3u, 3u, 3u, 3u), "splat ctor")
    }
