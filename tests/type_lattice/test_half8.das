}

def roundtrip_half8(v : half8) : half8 => v

[test]
def test_half8_conformance(t : T?) {
    t |> run("sizeof and alignof") @(t : T?) {
        t |> equal(typeinfo sizeof(type<half8>), 16)
        t |> equal(typeinfo alignof(type<half8>), 2)
    }
    t |> run("zero init and default") @(t : T?) {
        let z : half8
        t |> success(z == half8(0., 0., 0., 0., 0., 0., 0., 0.), "zero init")
        t |> success(default<half8> == half8(0., 0., 0., 0., 0., 0., 0., 0.), "default<>")
    }
    t |> run("ctor and equality") @(t : T?) {
        let a = half8(1., 2., 3., 4., 5., 6., 7., 8.)
        let b = half8(1., 2., 3., 4., 5., 6., 7., 8.)
        let c = half8(2., 3., 4., 5., 6., 7., 8., 9.)
        t |> success(a == b, "a == b")
        t |> success(a != c, "a != c")
        t |> success(half8(3.) == half8(3., 3., 3., 3., 3., 3., 3., 3.), "splat ctor")
    }
    t |> run("copy is value copy") @(t : T?) {
        let a = half8(1., 2., 3., 4., 5., 6., 7., 8.)
        var c = a
        c = half8(5., 6., 7., 8., 9., 10., 11., 12.)
        t |> success(a == half8(1., 2., 3., 4., 5., 6., 7., 8.), "source unchanged")
        t |> success(c == half8(5., 6., 7., 8., 9., 10., 11., 12.), "copy reassigned")
    }
    t |> run("pass and return by value") @(t : T?) {
        let a = half8(1., 2., 3., 4., 5., 6., 7., 8.)
        t |> success(roundtrip_half8(a) == a, "roundtrip")
    }
    t |> run("index read and write") @(t : T?) {
        var a = half8(1., 2., 3., 4., 5., 6., 7., 8.)
        t |> equal(a[0], 1h)
        t |> equal(a[1], 2h)
        t |> equal(a[2], 3h)
        t |> equal(a[3], 4h)
        t |> equal(a[4], 5h)
        t |> equal(a[5], 6h)
        t |> equal(a[6], 7h)
        t |> equal(a[7], 8h)
        a[7] = 9h
        t |> equal(a[7], 9h)
    }
    t |> run("s-namespace swizzle") @(t : T?) {
        var a = half8(1., 2., 3., 4., 5., 6., 7., 8.)
        t |> equal(a.s7, 8h)
        t |> success(a.s70 == half2(8., 1.), "pair reorder")
        t |> success(a.lo == half4(1., 2., 3., 4.), ".lo")
        t |> success(a.hi == half4(5., 6., 7., 8.), ".hi")
        a.s0 = 9h
        t |> equal(a.s0, 9h)
    }
    t |> run("struct field and layout") @(t : T?) {
        var w = Wrap_half8(pad = uint8(1), v = half8(1., 2., 3., 4., 5., 6., 7., 8.))
        t |> success(w.v == half8(1., 2., 3., 4., 5., 6., 7., 8.), "field read")
        w.v = half8(5., 6., 7., 8., 9., 10., 11., 12.)
        t |> success(w.v == half8(5., 6., 7., 8., 9., 10., 11., 12.), "field write")
        t |> equal(typeinfo sizeof(type<Wrap_half8>), 18)
    }
    t |> run("array element") @(t : T?) {
        var arr : array<half8>
        arr |> push(half8(1., 2., 3., 4., 5., 6., 7., 8.))
        arr |> push(half8(5., 6., 7., 8., 9., 10., 11., 12.))
        t |> equal(length(arr), 2)
        t |> success(arr[0] == half8(1., 2., 3., 4., 5., 6., 7., 8.), "array read 0")
        t |> success(arr[1] == half8(5., 6., 7., 8., 9., 10., 11., 12.), "array read 1")
        delete arr
    }
    t |> run("archive round trip") @(t : T?) {
        var a = half8(1., 2., 3., 4., 5., 6., 7., 8.)
        var data <- mem_archive_save(a)
        var back : half8
        data |> mem_archive_load(back)
        delete data
        t |> success(back == a, "mem archive")
    }
    t |> run("print") @(t : T?) {
        let a = half8(1., 2., 3., 4., 5., 6., 7., 8.)
        let s = "{a}"
        t |> success(!empty(s), "interpolates")
    }
    t |> run("arithmetic") @(t : T?) {
        let a = half8(1., 2., 3., 4., 5., 6., 7., 8.)
        let b = half8(2., 4., 6., 8., 10., 12., 14., 16.)
        t |> success(a + b == half8(3., 6., 9., 12., 15., 18., 21., 24.), "add")
        t |> success(b - a == half8(1., 2., 3., 4., 5., 6., 7., 8.), "sub")
        t |> success(a * b == half8(2., 8., 18., 32., 50., 72., 98., 128.), "mul")
        t |> success(b / a == half8(2., 2., 2., 2., 2., 2., 2., 2.), "div")
    }
