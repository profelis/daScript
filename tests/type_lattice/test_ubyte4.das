[test]
def test_ubyte4_conformance(t : T?) {
    t |> run("sizeof and alignof") @(t : T?) {
        t |> equal(typeinfo sizeof(type<ubyte4>), 4)
        t |> equal(typeinfo alignof(type<ubyte4>), 1)
    }
    t |> run("zero init and default") @(t : T?) {
        let z : ubyte4
        t |> success(z == ubyte4(0u, 0u, 0u, 0u), "zero init")
        t |> success(default<ubyte4> == ubyte4(0u, 0u, 0u, 0u), "default<>")
    }
    t |> run("ctor and equality") @(t : T?) {
        let a = ubyte4(1u, 2u, 3u, 4u)
        let b = ubyte4(1u, 2u, 3u, 4u)
        let c = ubyte4(2u, 3u, 4u, 5u)
        t |> success(a == b, "a == b")
        t |> success(a != c, "a != c")
        t |> success(ubyte4(3u) == ubyte4(3u, 3u, 3u, 3u), "splat ctor")
    }
    t |> run("copy is value copy") @(t : T?) {
        let a = ubyte4(1u, 2u, 3u, 4u)
        var c = a
        c = ubyte4(5u, 6u, 7u, 8u)
        t |> success(a == ubyte4(1u, 2u, 3u, 4u), "source unchanged")
        t |> success(c == ubyte4(5u, 6u, 7u, 8u), "copy reassigned")
    }
    t |> run("pass and return by value") @(t : T?) {
        let a = ubyte4(1u, 2u, 3u, 4u)
        t |> success(roundtrip_ubyte4(a) == a, "roundtrip")
    }
    t |> run("index read and write") @(t : T?) {
        var a = ubyte4(1u, 2u, 3u, 4u)
        t |> equal(a[0], uint8(1))
        t |> equal(a[1], uint8(2))
        t |> equal(a[2], uint8(3))
        t |> equal(a[3], uint8(4))
        a[3] = uint8(9)
        t |> equal(a[3], uint8(9))
    }
    t |> run("swizzle") @(t : T?) {
        var a = ubyte4(1u, 2u, 3u, 4u)
        t |> equal(a.x, uint8(1))
        t |> equal(a.w, uint8(4))
        t |> success(a.wzyx == ubyte4(4u, 3u, 2u, 1u), "reverse read")
        t |> success(a.xy == ubyte2(1u, 2u), "pair read")
        a.w = uint8(9)
        t |> equal(a.w, uint8(9))
        a.xy = ubyte2(7u, 8u)
        t |> equal(a.x, uint8(7))
        t |> equal(a.y, uint8(8))
    }
    t |> run("s-namespace swizzle") @(t : T?) {
        var a = ubyte4(1u, 2u, 3u, 4u)
        t |> equal(a.s3, uint8(4))
        t |> success(a.s30 == ubyte2(4u, 1u), "pair reorder")
        a.s0 = uint8(9)
        t |> equal(a.s0, uint8(9))
    }
    t |> run("struct field and layout") @(t : T?) {
        var w = Wrap_ubyte4(pad = uint8(1), v = ubyte4(1u, 2u, 3u, 4u))
        t |> success(w.v == ubyte4(1u, 2u, 3u, 4u), "field read")
        w.v = ubyte4(5u, 6u, 7u, 8u)
        t |> success(w.v == ubyte4(5u, 6u, 7u, 8u), "field write")
        t |> equal(typeinfo sizeof(type<Wrap_ubyte4>), 5)
    }
    t |> run("array element") @(t : T?) {
        var arr : array<ubyte4>
        arr |> push(ubyte4(1u, 2u, 3u, 4u))
        arr |> push(ubyte4(5u, 6u, 7u, 8u))
        t |> equal(length(arr), 2)
        t |> success(arr[0] == ubyte4(1u, 2u, 3u, 4u), "array read 0")
        t |> success(arr[1] == ubyte4(5u, 6u, 7u, 8u), "array read 1")
        delete arr
    }
    t |> run("archive round trip") @(t : T?) {
        var a = ubyte4(1u, 2u, 3u, 4u)
        var data <- mem_archive_save(a)
        var back : ubyte4
        data |> mem_archive_load(back)
        delete data
        t |> success(back == a, "mem archive")
    }
    t |> run("print") @(t : T?) {
        let a = ubyte4(1u, 2u, 3u, 4u)
        let s = "{a}"
        t |> success(!empty(s), "interpolates")
    }
}
