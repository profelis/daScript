}

def roundtrip_ubyte8(v : ubyte8) : ubyte8 => v

[test]
def test_ubyte8_conformance(t : T?) {
    t |> run("sizeof and alignof") @(t : T?) {
        t |> equal(typeinfo sizeof(type<ubyte8>), 8)
        t |> equal(typeinfo alignof(type<ubyte8>), 1)
    }
    t |> run("zero init and default") @(t : T?) {
        let z : ubyte8
        t |> success(z == ubyte8(0u, 0u, 0u, 0u, 0u, 0u, 0u, 0u), "zero init")
        t |> success(default<ubyte8> == ubyte8(0u, 0u, 0u, 0u, 0u, 0u, 0u, 0u), "default<>")
    }
    t |> run("ctor and equality") @(t : T?) {
        let a = ubyte8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u)
        let b = ubyte8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u)
        let c = ubyte8(2u, 3u, 4u, 5u, 6u, 7u, 8u, 9u)
        t |> success(a == b, "a == b")
        t |> success(a != c, "a != c")
        t |> success(ubyte8(3u) == ubyte8(3u, 3u, 3u, 3u, 3u, 3u, 3u, 3u), "splat ctor")
    }
    t |> run("copy is value copy") @(t : T?) {
        let a = ubyte8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u)
        var c = a
        c = ubyte8(5u, 6u, 7u, 8u, 9u, 10u, 11u, 12u)
        t |> success(a == ubyte8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u), "source unchanged")
        t |> success(c == ubyte8(5u, 6u, 7u, 8u, 9u, 10u, 11u, 12u), "copy reassigned")
    }
    t |> run("pass and return by value") @(t : T?) {
        let a = ubyte8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u)
        t |> success(roundtrip_ubyte8(a) == a, "roundtrip")
    }
    t |> run("index read and write") @(t : T?) {
        var a = ubyte8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u)
        t |> equal(a[0], uint8(1))
        t |> equal(a[1], uint8(2))
        t |> equal(a[2], uint8(3))
        t |> equal(a[3], uint8(4))
        t |> equal(a[4], uint8(5))
        t |> equal(a[5], uint8(6))
        t |> equal(a[6], uint8(7))
        t |> equal(a[7], uint8(8))
        a[7] = uint8(9)
        t |> equal(a[7], uint8(9))
    }
    t |> run("s-namespace swizzle") @(t : T?) {
        var a = ubyte8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u)
        t |> equal(a.s7, uint8(8))
        t |> success(a.s70 == ubyte2(8u, 1u), "pair reorder")
        t |> success(a.lo == ubyte4(1u, 2u, 3u, 4u), ".lo")
        t |> success(a.hi == ubyte4(5u, 6u, 7u, 8u), ".hi")
        a.s0 = uint8(9)
        t |> equal(a.s0, uint8(9))
    }
    t |> run("struct field and layout") @(t : T?) {
        var w = Wrap_ubyte8(pad = uint8(1), v = ubyte8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u))
        t |> success(w.v == ubyte8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u), "field read")
        w.v = ubyte8(5u, 6u, 7u, 8u, 9u, 10u, 11u, 12u)
        t |> success(w.v == ubyte8(5u, 6u, 7u, 8u, 9u, 10u, 11u, 12u), "field write")
        t |> equal(typeinfo sizeof(type<Wrap_ubyte8>), 9)
    }
    t |> run("array element") @(t : T?) {
        var arr : array<ubyte8>
        arr |> push(ubyte8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u))
        arr |> push(ubyte8(5u, 6u, 7u, 8u, 9u, 10u, 11u, 12u))
        t |> equal(length(arr), 2)
        t |> success(arr[0] == ubyte8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u), "array read 0")
        t |> success(arr[1] == ubyte8(5u, 6u, 7u, 8u, 9u, 10u, 11u, 12u), "array read 1")
        delete arr
    }
    t |> run("archive round trip") @(t : T?) {
        var a = ubyte8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u)
        var data <- mem_archive_save(a)
        var back : ubyte8
        data |> mem_archive_load(back)
        delete data
        t |> success(back == a, "mem archive")
    }
    t |> run("print") @(t : T?) {
        let a = ubyte8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u)
        let s = "{a}"
        t |> success(!empty(s), "interpolates")
    }
    t |> run("converts") @(t : T?) {
        let a = ubyte8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u)
        let w = ushort8(a)
        t |> success(w == ushort8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u), "widen")
        t |> success(ubyte8(w) == a, "narrow round trip")
        let s = ubyte8_sat(ushort8(30000u, 1u, 2u, 3u, 4u, 5u, 6u, 7u))
        t |> success(s == ubyte8(255u, 1u, 2u, 3u, 4u, 5u, 6u, 7u), "sat clamp")
    }
}
