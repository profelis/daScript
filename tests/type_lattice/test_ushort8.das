[test]
def test_ushort8_conformance(t : T?) {
    t |> run("sizeof and alignof") @(t : T?) {
        t |> equal(typeinfo sizeof(type<ushort8>), 16)
        t |> equal(typeinfo alignof(type<ushort8>), 2)
    }
    t |> run("zero init and default") @(t : T?) {
        let z : ushort8
        t |> success(z == ushort8(0u, 0u, 0u, 0u, 0u, 0u, 0u, 0u), "zero init")
        t |> success(default<ushort8> == ushort8(0u, 0u, 0u, 0u, 0u, 0u, 0u, 0u), "default<>")
    }
    t |> run("ctor and equality") @(t : T?) {
        let a = ushort8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u)
        let b = ushort8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u)
        let c = ushort8(2u, 3u, 4u, 5u, 6u, 7u, 8u, 9u)
        t |> success(a == b, "a == b")
        t |> success(a != c, "a != c")
        t |> success(ushort8(3u) == ushort8(3u, 3u, 3u, 3u, 3u, 3u, 3u, 3u), "splat ctor")
    }
    t |> run("copy is value copy") @(t : T?) {
        let a = ushort8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u)
        var c = a
        c = ushort8(5u, 6u, 7u, 8u, 9u, 10u, 11u, 12u)
        t |> success(a == ushort8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u), "source unchanged")
        t |> success(c == ushort8(5u, 6u, 7u, 8u, 9u, 10u, 11u, 12u), "copy reassigned")
    }
    t |> run("pass and return by value") @(t : T?) {
        let a = ushort8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u)
        t |> success(roundtrip_ushort8(a) == a, "roundtrip")
    }
    t |> run("index read and write") @(t : T?) {
        var a = ushort8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u)
        t |> equal(a[0], uint16(1))
        t |> equal(a[1], uint16(2))
        t |> equal(a[2], uint16(3))
        t |> equal(a[3], uint16(4))
        t |> equal(a[4], uint16(5))
        t |> equal(a[5], uint16(6))
        t |> equal(a[6], uint16(7))
        t |> equal(a[7], uint16(8))
        a[7] = uint16(9)
        t |> equal(a[7], uint16(9))
    }
    t |> run("s-namespace swizzle") @(t : T?) {
        var a = ushort8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u)
        t |> equal(a.s7, uint16(8))
        t |> success(a.s70 == ushort2(8u, 1u), "pair reorder")
        t |> success(a.lo == ushort4(1u, 2u, 3u, 4u), ".lo")
        t |> success(a.hi == ushort4(5u, 6u, 7u, 8u), ".hi")
        a.s0 = uint16(9)
        t |> equal(a.s0, uint16(9))
    }
    t |> run("struct field and layout") @(t : T?) {
        var w = Wrap_ushort8(pad = uint8(1), v = ushort8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u))
        t |> success(w.v == ushort8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u), "field read")
        w.v = ushort8(5u, 6u, 7u, 8u, 9u, 10u, 11u, 12u)
        t |> success(w.v == ushort8(5u, 6u, 7u, 8u, 9u, 10u, 11u, 12u), "field write")
        t |> equal(typeinfo sizeof(type<Wrap_ushort8>), 18)
    }
    t |> run("array element") @(t : T?) {
        var arr : array<ushort8>
        arr |> push(ushort8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u))
        arr |> push(ushort8(5u, 6u, 7u, 8u, 9u, 10u, 11u, 12u))
        t |> equal(length(arr), 2)
        t |> success(arr[0] == ushort8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u), "array read 0")
        t |> success(arr[1] == ushort8(5u, 6u, 7u, 8u, 9u, 10u, 11u, 12u), "array read 1")
        delete arr
    }
    t |> run("archive round trip") @(t : T?) {
        var a = ushort8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u)
        var data <- mem_archive_save(a)
        var back : ushort8
        data |> mem_archive_load(back)
        delete data
        t |> success(back == a, "mem archive")
    }
    t |> run("print") @(t : T?) {
        let a = ushort8(1u, 2u, 3u, 4u, 5u, 6u, 7u, 8u)
        let s = "{a}"
        t |> success(!empty(s), "interpolates")
    }
}
