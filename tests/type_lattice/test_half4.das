        let a = half4(1., 2., 3., 4.)
        let s = "{a}"
        t |> success(!empty(s), "interpolates")
    }
    t |> run("arithmetic") @(t : T?) {
        let a = half4(1., 2., 3., 4.)
        let b = half4(2., 4., 6., 8.)
        t |> success(a + b == half4(3., 6., 9., 12.), "add")
        t |> success(b - a == half4(1., 2., 3., 4.), "sub")
        t |> success(a * b == half4(2., 8., 18., 32.), "mul")
