// GENERATED by utils/dasgen/gen_shader_conformance.das — DO NOT EDIT
// regen: daslang utils/dasgen/gen_shader_conformance.das
options gen2
options indenting = 4
options no_aot     // invokes the compiler at runtime (compile_file) — not AOT-linkable

// Fail-closed conformance rows: each fixture uses one shader-illegal type; the emitter
// must reject with a clean diagnostic (same contract as tests/spirv/test_fail_closed.das).

require dastest/testing_boost public
require daslib/ast
require strings

def private compile_issues(file_path : string) : tuple<ok : bool; issues : string> {
    var okFlag = false
    var issuesText = ""
    var inscope access <- make_file_access("")
    using() $(var mg : ModuleGroup) {
        using() $(var cop : CodeOfPolicies) {
            cop.threadlock_context = true
            compile_file(file_path, access, unsafe(addr(mg)), cop) $(ok, _program, issues) {
                okFlag = ok
                issuesText := issues
            }
        }
    }
    return (ok = okFlag, issues = issuesText)
}

def private check_rejects(t : T?; fixture, needle : string) {
    let r = compile_issues("{get_das_root()}/tests/spirv/_fail_closed/{fixture}.das")
    t |> success(!r.ok, "{fixture}: compilation fails (fail-closed)")
    t |> success(find(r.issues, needle) >= 0, "{fixture}: error mentions '{needle}'")
    if (r.ok || find(r.issues, needle) < 0) {
        to_log(LOG_ERROR, "FAIL-CLOSED {fixture}: ok={r.ok}, issues=\n{r.issues}\n")
    }
}

[test]
def test_conf_rejects_spirv(t : T?) {
    t |> run("conformance reject rows fail closed") <| @(t : T?) {
        check_rejects(t, "_fc_conf_double", "tDouble is not supported")
        check_rejects(t, "_fc_conf_float16", "type tFloat16 is not supported")
        check_rejects(t, "_fc_conf_half2", "type tHalf2 is not supported")
        check_rejects(t, "_fc_conf_half3", "type tHalf3 is not supported")
        check_rejects(t, "_fc_conf_half4", "type tHalf4 is not supported")
        check_rejects(t, "_fc_conf_half8", "is CPU-only")
        check_rejects(t, "_fc_conf_int8", "type tInt8 is not supported")
        check_rejects(t, "_fc_conf_uint8", "type tUInt8 is not supported")
        check_rejects(t, "_fc_conf_int16", "type tInt16 is not supported")
        check_rejects(t, "_fc_conf_uint16", "type tUInt16 is not supported")
        check_rejects(t, "_fc_conf_short2", "type tShort2 is not supported")
        check_rejects(t, "_fc_conf_short3", "type tShort3 is not supported")
        check_rejects(t, "_fc_conf_short4", "type tShort4 is not supported")
        check_rejects(t, "_fc_conf_short8", "is CPU-only")
        check_rejects(t, "_fc_conf_ushort2", "type tUShort2 is not supported")
        check_rejects(t, "_fc_conf_ushort3", "type tUShort3 is not supported")
        check_rejects(t, "_fc_conf_ushort4", "type tUShort4 is not supported")
        check_rejects(t, "_fc_conf_ushort8", "is CPU-only")
        check_rejects(t, "_fc_conf_byte2", "type tByte2 is not supported")
        check_rejects(t, "_fc_conf_byte3", "type tByte3 is not supported")
        check_rejects(t, "_fc_conf_byte4", "type tByte4 is not supported")
        check_rejects(t, "_fc_conf_byte8", "is CPU-only")
        check_rejects(t, "_fc_conf_byte16", "is CPU-only")
        check_rejects(t, "_fc_conf_ubyte2", "type tUByte2 is not supported")
        check_rejects(t, "_fc_conf_ubyte3", "type tUByte3 is not supported")
        check_rejects(t, "_fc_conf_ubyte4", "type tUByte4 is not supported")
        check_rejects(t, "_fc_conf_ubyte8", "is CPU-only")
        check_rejects(t, "_fc_conf_ubyte16", "is CPU-only")
        check_rejects(t, "_fc_lattice_ubo", "field 'h': type tHalf4 is not supported")
        check_rejects(t, "_fc_lattice_ssbo", "element type tHalf4 is not supported")
        check_rejects(t, "_fc_lattice_push", "field 's': type tShort2 is not supported")
    }
}
