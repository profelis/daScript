+        // quantized leaf tensors into the matching CPU extra buffer type so extra-buft GEMM
+        // paths (AMX mmq / repack) engage in perf mode — the default CPU buffer never does.
+        std::vector<ggml_backend_buffer_ptr> weight_bufs;
+        if (const char * want = getenv("GGML_PERF_WEIGHT_BUFT")) {
+            ggml_backend_buffer_type_t wbuft = nullptr;
+            ggml_backend_dev_t dev = ggml_backend_get_device(backend);
+            ggml_backend_reg_t reg = dev ? ggml_backend_dev_backend_reg(dev) : nullptr;
+            auto get_extra_fn = reg ? (ggml_backend_dev_get_extra_bufts_t)
+                ggml_backend_reg_get_proc_address(reg, "ggml_backend_dev_get_extra_bufts") : nullptr;
+            if (get_extra_fn != nullptr) {
+                for (ggml_backend_buffer_type_t * b = get_extra_fn(dev); b && *b; ++b) {
+                    if (strstr(ggml_backend_buft_name(*b), want) != nullptr) { wbuft = *b; break; }
+                }
+            }
+            for (ggml_tensor * t = wbuft ? ggml_get_first_tensor(ctx.get()) : nullptr;
